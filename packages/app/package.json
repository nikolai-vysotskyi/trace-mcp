{
  "name": "trace-mcp-app",
  "version": "1.33.0",
  "private": true,
  "description": "trace-mcp menu bar app",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc -p tsconfig.main.json && node scripts/patch-electron-dev.mjs && unset ELECTRON_RUN_AS_NODE && electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "node scripts/patch-electron-dev.mjs",
    "generate-icons": "node scripts/generate-icons.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cosmos.gl/graph": "3.0.0-beta.8",
    "menubar": "^9.5.0"
  },
  "overrides": {
    "@luma.gl/core": "9.2.6",
    "@luma.gl/engine": "9.2.6",
    "@luma.gl/webgl": "9.2.6",
    "menubar": {
      "electron": "$electron"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.3",
    "vite": "^6.3.2"
  }
}
